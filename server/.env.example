# Trinetra Digital CRM & WhatsApp Automation Backend Configuration

# ── NETWORK SETTINGS ──────────────────────────────────────────────────────────
# The active port for the Express REST web server
PORT=5000

# ── DATABASE & SESSION PERSISTENCE ───────────────────────────────────────────
# Path to the SQLite WAL database file (created automatically if missing)
DATABASE_PATH=./data/trinetra.db

# Path to the WhatsApp Baileys credentials folder (pairs and stays persistent)
WHATSAPP_SESSION_PATH=./data/wa-session

# ── SECURITY CREDENTIALS ─────────────────────────────────────────────────────
# A secure JWT signature token used to sign administrator dashboard sessions
JWT_SECRET=your_super_secret_long_random_hash_key_here

# ── INTEGRATION KEYSETS ──────────────────────────────────────────────────────
# Google Gemini API credential used for automated BANT scoring & conversations
# Grab a free key here: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_SECURE_GEMINI_API_KEY_HERE

# ── OPTIONAL FRONTEND MAPPINGS ────────────────────────────────────────────────
# Allowed CORS origins (e.g. for custom Vercel deployments)
FRONTEND_URL=https://your-dashboard-deployment.vercel.app
NODE_ENV=production
